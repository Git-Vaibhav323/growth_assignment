# Copy this file to .env and fill in the values you need.
# The app runs with zero configuration (AI_PROVIDER=mock) — switch to a real
# provider below once you're ready to test/deploy real AI extraction.

PORT=4000
NODE_ENV=development

# The frontend origin allowed to call this API (CORS). Update this to your
# deployed Vercel URL in production. Comma-separate multiple origins for local
# dev (e.g. Next.js may pick port 3001 if 3000 is busy).
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ---- AI provider -----------------------------------------------------------
# One of: mock | openai | anthropic | gemini | groq
# "mock" needs no key at all and is just for a zero-setup local demo — it
# uses simple header-name matching, not real language understanding. Switch
# this to a real provider before you deploy/submit; that's the part the
# assignment is actually evaluating.
#
# Cost note: OpenAI and Anthropic generally require a payment method on the
# account before the API works. Gemini (Google AI Studio) and Groq both have
# genuinely free tiers — no card required, just rate limits — which makes
# either the option to reach for if you want $0. Verify current terms on
# each provider's site; they change.
AI_PROVIDER=mock

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Batching / resilience --------------------------------------------------
BATCH_SIZE=20
AI_CONCURRENCY=3
AI_MAX_RETRIES=3

MAX_UPLOAD_MB=10
